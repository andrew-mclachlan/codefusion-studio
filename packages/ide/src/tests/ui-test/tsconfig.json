{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "es2020",
    "lib": ["es2020"],
    "outDir": "../../../out/", // compiled JS goes here
    "moduleResolution": "node",
    "strict": true,
    "noImplicitAny": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  }
}
